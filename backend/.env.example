APP_NAME=Neighbord Community System
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5174

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Opcional, pero recomendado para crear toda la base con el instalador.
# Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.tu-ref:tu-password@aws-0-region.pooler.supabase.com:6543/postgres

JWT_SECRET_KEY=cambia-esta-clave-en-produccion
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

MAIL_USERNAME=
# Gmail requiere una clave de aplicacion de 16 caracteres, no la clave normal de la cuenta.
# Puedes pegarla con o sin espacios; el backend quitara los espacios antes de iniciar sesion.
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=Neighbord
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

ADMIN_NAME=Administrador Neighbord
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=CambiaEstaClave123

# WhatsApp / Twilio (opcional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=whatsapp:+1234567890
WHATSAPP_ENABLED=false

# Redis (opcional para caching)
REDIS_URL=redis://localhost:6379/0

# Elasticsearch (opcional para búsqueda)
ELASTICSEARCH_URL=http://localhost:9200

# Strike API Configuration (para pagos con Lightning Network)
# Obtén tu API key en https://dashboard.strike.me/developers
STRIKE_API_KEY=
